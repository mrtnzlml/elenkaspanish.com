---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Spanish with Elena Ramón — Your Spanish, Your Adventure",
  description = "Personalized online Spanish lessons with a native speaker. Tailor-made classes for all levels.",
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Spanish with Elena Ramón",
  description:
    "Personalized online Spanish lessons with a native speaker. Tailor-made classes for all levels.",
  url: "https://elenkaspanish.com",
  email: "elenka.mrm@gmail.com",
  telephone: "+420773710520",
  image: "https://elenkaspanish.com/elena.jpg",
  priceRange: "24 USD",
  address: {
    "@type": "PostalAddress",
    addressCountry: "CZ",
  },
  sameAs: [],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://elenkaspanish.com/elena.jpg" />
    <meta property="og:url" content="https://elenkaspanish.com" />
    <meta property="og:site_name" content="Spanish with Elena Ramón" />

    <!-- Font preload -->
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/manrope/v15/xn7_YHE41ni1AdIRqAuZuw1Bx9mbZk59FO_F87jxeN7B.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/manrope/v15/xn7_YHE41ni1AdIRqAuZuw1Bx9mbZk4GE-_F87jxeN7B.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <style>
      .nav-open {
        display: flex !important;
      }
    </style>
  </head>
  <body class="bg-cream text-gray-800 font-sans antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-lg">
      Skip to content
    </a>
    <header class="border-b border-gray-200 sticky top-0 z-50 bg-cream/95 backdrop-blur-sm">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between" aria-label="Main navigation">
        <a href="/" class="text-xl font-bold text-primary">
          Elenka Spanish
        </a>

        <!-- Hamburger button (mobile) -->
        <button
          id="menu-toggle"
          class="md:hidden flex flex-col gap-1.5 p-2 -mr-2 cursor-pointer"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <span class="block w-6 h-0.5 bg-gray-800 transition-transform" id="bar1"></span>
          <span class="block w-6 h-0.5 bg-gray-800 transition-opacity" id="bar2"></span>
          <span class="block w-6 h-0.5 bg-gray-800 transition-transform" id="bar3"></span>
        </button>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-6">
          <a href="/#pricing" class="hover:text-primary transition-colors">Pricing</a>
          <a href="/#about" class="hover:text-primary transition-colors">About</a>
          <a href="/games" class="hover:text-primary transition-colors">Practice</a>
          <a
            href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ38hp0IO46XB7FQXk_vZXUAaaMVejyjSFGxa-NanSFJbN9S2_Asp_kl-_YddbRWDI3HbtKwGgcW"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-primary text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors"
          >
            Book Free Call
          </a>
        </div>
      </nav>

      <!-- Mobile nav -->
      <div
        id="mobile-menu"
        class="hidden flex-col gap-4 px-6 pb-6 md:hidden border-t border-gray-200"
      >
        <a href="/#pricing" class="hover:text-primary transition-colors py-1">Pricing</a>
        <a href="/#about" class="hover:text-primary transition-colors py-1">About</a>
        <a href="/games" class="hover:text-primary transition-colors py-1">Practice</a>
        <a
          href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ38hp0IO46XB7FQXk_vZXUAaaMVejyjSFGxa-NanSFJbN9S2_Asp_kl-_YddbRWDI3HbtKwGgcW"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors text-center"
        >
          Book Free Call
        </a>
      </div>
    </header>

    <main id="main-content" class="relative overflow-hidden">
      <!-- Global decorative blobs -->
      <div class="absolute top-0 right-0 w-[30rem] h-[30rem] bg-primary/[0.04] rounded-full blur-[120px] -z-10" aria-hidden="true"></div>
      <div class="absolute bottom-0 left-0 w-[25rem] h-[25rem] bg-primary/[0.04] rounded-full blur-[120px] -z-10" aria-hidden="true"></div>
      <slot />
    </main>

    <footer class="border-t border-gray-200 mt-16">
      <div class="max-w-4xl mx-auto px-6 py-10">
        <div class="grid sm:grid-cols-3 gap-8 mb-8">
          <div>
            <p class="font-bold text-primary mb-3">Elenka Spanish</p>
            <p class="text-sm text-gray-500 leading-relaxed">Personalized online Spanish lessons with a native Mexican teacher.</p>
          </div>
          <div>
            <p class="font-bold mb-3">Quick Links</p>
            <nav class="flex flex-col gap-2 text-sm text-gray-500">
              <a href="/#pricing" class="hover:text-primary transition-colors">Pricing</a>
              <a href="/#about" class="hover:text-primary transition-colors">About Elena</a>
              <a href="/#faq" class="hover:text-primary transition-colors">FAQ</a>
              <a href="/games" class="hover:text-primary transition-colors">Practice Games</a>
            </nav>
          </div>
          <div>
            <p class="font-bold mb-3">Get in Touch</p>
            <nav class="flex flex-col gap-2 text-sm text-gray-500">
              <a href="mailto:elenka.mrm@gmail.com" class="hover:text-primary transition-colors">elenka.mrm@gmail.com</a>
              <a href="https://wa.me/420773710520" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">WhatsApp: +420 773 710 520</a>
              <a
                href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ38hp0IO46XB7FQXk_vZXUAaaMVejyjSFGxa-NanSFJbN9S2_Asp_kl-_YddbRWDI3HbtKwGgcW"
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary font-bold hover:underline"
              >
                Book a free call
              </a>
            </nav>
          </div>
        </div>
        <div class="border-t border-gray-200 pt-6 text-center text-sm text-gray-500">
          &copy; {new Date().getFullYear()} Spanish with Elena Ramón. All rights reserved.
        </div>
      </div>
    </footer>

    <!-- Floating WhatsApp button -->
    <a
      href="https://wa.me/420773710520"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] text-white rounded-full flex items-center justify-center shadow-lg hover:shadow-xl hover:scale-110 transition-all cursor-pointer"
      aria-label="Chat on WhatsApp"
    >
      <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>

    <!-- Sticky mobile CTA bar -->
    <div id="mobile-cta" class="fixed bottom-0 left-0 right-0 z-40 bg-white/95 backdrop-blur-sm border-t border-gray-200 px-4 py-3 md:hidden hidden">
      <a
        href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ38hp0IO46XB7FQXk_vZXUAaaMVejyjSFGxa-NanSFJbN9S2_Asp_kl-_YddbRWDI3HbtKwGgcW"
        target="_blank"
        rel="noopener noreferrer"
        class="block bg-primary text-white text-center px-6 py-3 rounded-xl font-bold hover:bg-blue-700 transition-colors shadow-lg shadow-primary/20 mr-16"
      >
        Book a free call
      </a>
    </div>

    <script>
      const toggle = document.getElementById("menu-toggle")!;
      const menu = document.getElementById("mobile-menu")!;
      const bar1 = document.getElementById("bar1")!;
      const bar2 = document.getElementById("bar2")!;
      const bar3 = document.getElementById("bar3")!;

      toggle.addEventListener("click", () => {
        const open = menu.classList.toggle("nav-open");
        toggle.setAttribute("aria-expanded", String(open));
        bar1.style.transform = open ? "rotate(45deg) translate(4px, 4px)" : "";
        bar2.style.opacity = open ? "0" : "1";
        bar3.style.transform = open ? "rotate(-45deg) translate(4px, -4px)" : "";
      });

      // Close mobile menu when a link is clicked
      menu.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          menu.classList.remove("nav-open");
          toggle.setAttribute("aria-expanded", "false");
          bar1.style.transform = "";
          bar2.style.opacity = "1";
          bar3.style.transform = "";
        });
      });

      // Scroll-triggered fade-in animations
      const fadeObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            fadeObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('main section').forEach((s, i) => {
        if (i === 0) return; // Hero visible immediately
        if (s.getBoundingClientRect().top < window.innerHeight) return; // Already in viewport
        s.classList.add('fade-in-section');
        fadeObserver.observe(s);
      });

      // Sticky mobile CTA — show after scrolling past 500px
      const mobileCta = document.getElementById("mobile-cta");
      if (mobileCta) {
        window.addEventListener("scroll", () => {
          if (window.scrollY > 500) {
            mobileCta.classList.remove("hidden");
          } else {
            mobileCta.classList.add("hidden");
          }
        }, { passive: true });
      }
    </script>
  </body>
</html>
