---
const bookingUrl =
  "https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ38hp0IO46XB7FQXk_vZXUAaaMVejyjSFGxa-NanSFJbN9S2_Asp_kl-_YddbRWDI3HbtKwGgcW";
---

<section id="hero" class="max-w-4xl mx-auto px-6 py-20 text-center">
  <p class="text-lg text-gray-500 mb-2">Elena María Ramón Martínez</p>
  <h1 class="text-4xl md:text-5xl font-bold text-primary mb-6">
    Your Spanish, Your Adventure.
  </h1>
  <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-10">
    Welcome to Elenka Spanish lessons, where you won't just learn a language;
    you'll connect with a fascinating culture and way of life!
  </p>
  <div class="flex flex-col sm:flex-row gap-4 justify-center">
    <a
      href={bookingUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-primary text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors"
    >
      Schedule a free 20-minute call
    </a>
    <a
      href="/questionnaire"
      class="border-2 border-primary text-primary px-6 py-3 rounded-lg font-bold hover:bg-primary hover:text-white transition-colors"
    >
      Start with a Questionnaire
    </a>
  </div>
</section>
