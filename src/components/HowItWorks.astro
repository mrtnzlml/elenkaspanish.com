---
const steps = [
  {
    number: "1",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V19.5a2.25 2.25 0 002.25 2.25h.75" />',
    title: "Fill the Questionnaire",
    description:
      "Tell me about your goals, level, and preferred learning style so I can prepare the perfect plan for you.",
  },
  {
    number: "2",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />',
    title: "Free 20-Minute Call",
    description:
      "We'll meet over Google Meet to get to know each other, discuss your goals, and answer any questions.",
  },
  {
    number: "3",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />',
    title: "Start Learning",
    description:
      "Begin your personalized Spanish lessons, tailored to your pace and interests. Pay only for the first lesson — no strings attached.",
  },
];
---

<section id="how-it-works" class="max-w-4xl mx-auto px-6 py-16">
  <h2 class="text-2xl md:text-3xl font-bold text-center text-primary mb-12">
    How It Works
  </h2>
  <div class="grid md:grid-cols-3 gap-8">
    {
      steps.map((step, i) => (
        <div class="text-center relative">
          {/* Connecting arrow to next step (desktop only) */}
          {i < steps.length - 1 && (
            <div class="hidden md:flex absolute top-10 -right-4 w-8 items-center justify-center" aria-hidden="true">
              <svg class="w-6 h-6 text-primary/25" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </div>
          )}
          <div class="w-20 h-20 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4 relative">
            <svg class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <Fragment set:html={step.icon} />
            </svg>
            <span class="absolute -top-2 -right-2 w-7 h-7 bg-primary text-white rounded-full flex items-center justify-center text-xs font-bold">{step.number}</span>
          </div>
          <h3 class="text-lg font-bold mb-2">{step.title}</h3>
          <p class="text-gray-600 leading-relaxed">{step.description}</p>
        </div>
      ))
    }
  </div>
</section>
