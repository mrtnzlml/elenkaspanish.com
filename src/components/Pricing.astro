---
const bookingUrl =
  "https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ38hp0IO46XB7FQXk_vZXUAaaMVejyjSFGxa-NanSFJbN9S2_Asp_kl-_YddbRWDI3HbtKwGgcW";
---

<section id="pricing" class="bg-white py-16">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-primary mb-8">Pricing</h2>
    <div
      class="inline-block bg-cream border-2 border-primary rounded-2xl p-10 shadow-sm"
    >
      <p class="text-gray-500 mb-2 font-bold uppercase tracking-wide text-sm">
        Lesson duration: 55 minutes
      </p>
      <p class="text-4xl font-bold text-primary mb-1">24 USD</p>
      <p class="text-gray-500">21 EUR / 500 CZK</p>
    </div>
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-primary text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors"
      >
        Schedule a free 20-minute call
      </a>
      <a
        href="/questionnaire"
        class="border-2 border-primary text-primary px-6 py-3 rounded-lg font-bold hover:bg-primary hover:text-white transition-colors"
      >
        Start with a Questionnaire
      </a>
    </div>
  </div>
</section>
