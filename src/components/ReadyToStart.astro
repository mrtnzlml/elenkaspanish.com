---
const bookingUrl =
  "https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ38hp0IO46XB7FQXk_vZXUAaaMVejyjSFGxa-NanSFJbN9S2_Asp_kl-_YddbRWDI3HbtKwGgcW";
---

<section class="bg-primary py-16">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-white mb-8">
      Ready to Start Your Spanish Adventure?
    </h2>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white text-primary px-6 py-3 rounded-lg font-bold hover:bg-gray-100 transition-colors"
      >
        Schedule a free 20-minute call
      </a>
      <a
        href="/questionnaire"
        class="border-2 border-white text-white px-6 py-3 rounded-lg font-bold hover:bg-white hover:text-primary transition-colors"
      >
        Start with a Questionnaire
      </a>
    </div>
  </div>
</section>
