---
const companies = [
  { name: "Letiště Praha", logo: "/logos/prague-airport.svg" },
  { name: "Loxia a.s.", logo: null },
  { name: "DentaLabs s.r.o.", logo: "/logos/dentalabs.svg" },
];
---

<section class="py-10 border-b border-gray-200/60">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs uppercase tracking-widest text-gray-500 text-center mb-6">
      Trusted by
    </p>
    <div class="flex flex-wrap items-center justify-center gap-10 md:gap-16">
      {
        companies.map((c) =>
          c.logo ? (
            <img
              src={c.logo}
              alt={c.name}
              class="h-8 md:h-10 w-auto opacity-40 grayscale hover:opacity-70 hover:grayscale-0 transition-all"
              loading="lazy"
            />
          ) : (
            <span class="text-xl md:text-2xl font-bold text-gray-800 opacity-25 hover:opacity-50 transition-opacity select-none tracking-wider uppercase">
              {c.name}
            </span>
          )
        )
      }
    </div>
  </div>
</section>
