---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Whiteboard — Spanish with Elena Ramón">
  <section class="px-2 py-2">
    <div class="mb-3 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-primary">Lesson Whiteboard</h1>
        <p class="text-gray-500 text-sm">A shared canvas for your lesson. Both teacher and student can draw, type, and annotate in real time.</p>
      </div>

      <!-- Controls -->
      <div class="flex items-center gap-3">
        <button id="btn-new" class="px-4 py-2 rounded-lg font-bold bg-primary text-white hover:bg-blue-700 transition-colors text-sm">
          New Session
        </button>
        <button id="btn-copy" class="px-4 py-2 rounded-lg font-bold border-2 border-gray-300 text-gray-600 hover:border-primary hover:text-primary transition-colors text-sm hidden">
          Copy Link
        </button>
        <span id="copy-feedback" class="text-xs text-green-600 font-bold hidden" role="status" aria-live="polite">Copied!</span>
      </div>
    </div>

    <!-- Whiteboard embed -->
    <div id="whiteboard-container" class="rounded-lg border border-gray-200 overflow-hidden bg-white" style="height: calc(100vh - 8rem);">
      <div id="placeholder" class="flex flex-col items-center justify-center h-full text-center px-6">
        <p class="text-5xl mb-4">&#9997;&#65039;</p>
        <h2 class="text-xl font-bold text-gray-700 mb-2">Start a whiteboard session</h2>
        <p class="text-gray-500 mb-6 max-w-md">Click "New Session" to create a collaborative whiteboard, or join an existing one by opening a shared link.</p>
      </div>
      <iframe
        id="whiteboard-frame"
        class="w-full h-full hidden"
        title="Collaborative whiteboard"
        allow="clipboard-read; clipboard-write"
      ></iframe>
    </div>

    <p class="text-xs text-gray-500 mt-3">
      Powered by <a href="https://excalidraw.com" target="_blank" rel="noopener noreferrer" class="underline hover:text-primary">Excalidraw</a>. Collaboration is end-to-end encrypted. Boards are not saved after the session ends.
    </p>
  </section>

  <script>
    const frame = document.getElementById("whiteboard-frame") as HTMLIFrameElement;
    const placeholder = document.getElementById("placeholder")!;
    const btnNew = document.getElementById("btn-new")!;
    const btnCopy = document.getElementById("btn-copy")!;
    const copyFeedback = document.getElementById("copy-feedback")!;

    function randomString(len: number): string {
      const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
      let id = "";
      for (let i = 0; i < len; i++) {
        id += chars[Math.floor(Math.random() * chars.length)];
      }
      return id;
    }

    function loadRoom(roomId: string, key: string) {
      const url = `https://excalidraw.com/#room=${roomId},${key}`;
      frame.src = url;
      frame.classList.remove("hidden");
      placeholder.classList.add("hidden");
      btnCopy.classList.remove("hidden");

      // Update URL so the link is shareable (includes key)
      const shareUrl = new URL(window.location.href);
      shareUrl.searchParams.set("room", roomId);
      shareUrl.searchParams.set("key", key);
      window.history.replaceState({}, "", shareUrl.toString());
    }

    // Check if joining an existing room from URL
    const params = new URLSearchParams(window.location.search);
    const existingRoom = params.get("room");
    const existingKey = params.get("key");
    if (existingRoom && existingKey) {
      loadRoom(existingRoom, existingKey);
    }

    btnNew.addEventListener("click", () => {
      loadRoom(randomString(20), randomString(22));
    });

    btnCopy.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyFeedback.classList.remove("hidden");
        setTimeout(() => copyFeedback.classList.add("hidden"), 2000);
      } catch {
        // Fallback
        const input = document.createElement("input");
        input.value = window.location.href;
        document.body.appendChild(input);
        input.select();
        document.execCommand("copy");
        document.body.removeChild(input);
        copyFeedback.classList.remove("hidden");
        setTimeout(() => copyFeedback.classList.add("hidden"), 2000);
      }
    });
  </script>
</Layout>
