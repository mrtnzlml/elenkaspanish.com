---
import Layout from "../layouts/Layout.astro";

const faqs = [
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />',
    question: "What do I need to take the classes?",
    answer:
      "You only need a stable internet connection, a device with a camera and microphone (computer, tablet, or smartphone), and a strong desire to learn. Classes are held via video call, using <strong>Google Meet</strong>.",
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />',
    question: "Can I cancel or reschedule a class?",
    answer:
      "Yes, of course. I just ask that you notify me at least <strong>24 hours in advance</strong> to reschedule at no extra cost. Cancellations with less than 24 hours' notice are non-refundable.",
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />',
    question: "Do you offer classes for children?",
    answer: "Currently, I specialize in teaching adults.",
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" />',
    question: "How is payment made?",
    answer:
      "Payment is made <strong>in advance</strong> for a package of <strong>4 classes</strong>. I accept bank transfers or Revolut payments, depending on your country. Once we schedule your classes, I will send you the payment details and instructions.",
  },
];
---

<Layout title="FAQ — Spanish with Elena Ramón">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-3xl md:text-4xl font-bold text-primary mb-12 text-center">
      Frequently Asked Questions
    </h1>
    <div class="space-y-6">
      {
        faqs.map((faq) => (
          <div class="p-6 rounded-xl border border-gray-200 bg-white flex gap-5">
            <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                <Fragment set:html={faq.icon} />
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-bold mb-2">{faq.question}</h2>
              <p class="text-gray-600 leading-relaxed" set:html={faq.answer} />
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
