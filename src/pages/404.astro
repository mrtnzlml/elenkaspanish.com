---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found — Spanish with Elena Ramón">
  <section class="max-w-2xl mx-auto px-6 py-24 text-center">
    <p class="text-6xl mb-6" aria-hidden="true">&#127758;</p>
    <h1 class="text-4xl font-bold text-primary mb-4">Page Not Found</h1>
    <p class="text-gray-600 mb-8">
      This page doesn't exist — but your Spanish adventure can still begin!
    </p>
    <a
      href="/"
      class="bg-primary text-white px-6 py-3 rounded-lg font-bold hover:bg-blue-700 transition-colors inline-block"
    >
      Back to Home
    </a>
  </section>
</Layout>
