---
import Layout from "../layouts/Layout.astro";

const googleFormUrl = "https://docs.google.com/forms/d/e/1FAIpQLSf-a1BezXT0CyRu6UDg5ajDekWuD2-8G5cAvrv5_WacjgMG6w/viewform?embedded=true";
---

<Layout title="Questionnaire — Spanish with Elena Ramón">
  <section class="max-w-3xl mx-auto px-6 py-16">
    <div class="text-center mb-10">
      <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V19.5a2.25 2.25 0 002.25 2.25h.75" />
        </svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-primary mb-4">
        Questionnaire
      </h1>
      <p class="text-gray-600">
        Do you want to start learning Spanish? Fill this form and let's get
        started.
      </p>
    </div>

    <div class="rounded-xl border border-gray-200 overflow-hidden bg-white shadow-sm">
      <iframe
        src={googleFormUrl}
        width="100%"
        height="1200"
        title="Student questionnaire"
        class="w-full border-0"
        loading="lazy"
      >
        Loading...
      </iframe>
    </div>

    <p class="text-sm text-gray-500 mt-6 text-center">
      After submission, payment instructions will be sent to you shortly. You
      will only need to pay for the first lesson, and then you can decide
      whether to continue with the whole course. No strings attached.
    </p>
  </section>
</Layout>
