---
import Layout from "../../layouts/Layout.astro";
import { categories } from "../../data/words";

const catMap = Object.fromEntries(categories.map((c) => [c.name, c.words]));
---

<Layout title="Flashcards — Spanish with Elena Ramón">
  <section class="max-w-2xl mx-auto px-6 py-12">
    <div class="mb-8">
      <a href="/games" class="text-sm text-primary hover:underline">&larr; All Games</a>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold text-primary mb-2 text-center">
      Spanish Flashcards
    </h1>
    <p class="text-gray-500 text-center mb-8">
      Click the card to flip it. How many can you get right?
    </p>

    <div id="category-picker" class="flex flex-wrap gap-2 justify-center mb-8">
      {
        categories.map((cat, i) => (
          <button
            data-category={cat.name}
            class:list={[
              "category-btn px-4 py-2 rounded-full text-sm font-bold transition-colors cursor-pointer",
              i === 0
                ? "bg-primary text-white"
                : "bg-gray-100 text-gray-600 hover:bg-gray-200",
            ]}
          >
            {cat.label}
          </button>
        ))
      }
    </div>

    <div class="flex items-center gap-4 mb-6">
      <div class="flex-1 h-2 bg-gray-200 rounded-full overflow-hidden">
        <div id="progress-bar" class="h-full bg-primary rounded-full transition-all duration-300" style="width: 0%" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
      </div>
      <span id="progress-text" class="text-sm text-gray-500 min-w-[4rem] text-right">0 / 15</span>
      <button id="btn-restart-mid" class="text-xs text-gray-500 hover:text-primary transition-colors cursor-pointer">Restart</button>
    </div>

    <div id="card-container" class="perspective-[800px] mb-8">
      <button id="flashcard" class="relative w-full h-64 cursor-pointer" aria-label="Flip card">
        <div id="card-inner" class="relative w-full h-full transition-transform duration-500" style="transform-style: preserve-3d;">
          <div class="absolute inset-0 rounded-2xl border-2 border-primary/20 bg-white shadow-lg flex flex-col items-center justify-center px-8 backface-hidden">
            <span class="text-xs uppercase tracking-wider text-gray-500 mb-3">Español</span>
            <span id="word-es" class="text-3xl font-bold text-primary text-center"></span>
          </div>
          <div id="card-back" class="absolute inset-0 rounded-2xl border-2 border-primary/20 bg-primary shadow-lg flex flex-col items-center justify-center px-8 backface-hidden invisible" style="transform: rotateY(180deg);">
            <span class="text-xs uppercase tracking-wider text-blue-200 mb-3">English</span>
            <span id="word-en" class="text-3xl font-bold text-white text-center"></span>
          </div>
        </div>
      </button>
    </div>

    <div id="actions" class="flex gap-4 justify-center mb-8 hidden">
      <button id="btn-again" class="flex-1 max-w-[10rem] px-6 py-3 rounded-lg font-bold border-2 border-red-400 text-red-600 hover:bg-red-50 transition-colors cursor-pointer">Practice again</button>
      <button id="btn-got-it" class="flex-1 max-w-[10rem] px-6 py-3 rounded-lg font-bold border-2 border-green-500 text-green-700 hover:bg-green-50 transition-colors cursor-pointer">Got it!</button>
    </div>

    <p id="flip-prompt" class="text-center text-sm text-gray-500">Tap the card to reveal the answer</p>

    <div id="results" class="text-center hidden">
      <p class="text-5xl mb-4" aria-hidden="true">&#127881;</p>
      <h2 class="text-2xl font-bold text-primary mb-2">Round Complete!</h2>
      <p id="results-score" class="text-gray-600 mb-2"></p>
      <p id="results-detail" class="text-sm text-gray-500 mb-6"></p>
      <div class="flex gap-4 justify-center">
        <button id="btn-retry-mistakes" class="px-6 py-3 rounded-lg font-bold border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors hidden cursor-pointer">Practice mistakes</button>
        <button id="btn-restart" class="px-6 py-3 rounded-lg font-bold bg-primary text-white hover:bg-blue-700 transition-colors cursor-pointer">Play again</button>
      </div>
    </div>
  </section>

  <script define:vars={{ catMap }}>
    const allCategories = catMap;
    let currentCategory = Object.keys(allCategories)[0];
    let deck = [], index = 0, correct = 0, mistakes = [], flipped = false;

    const $ = (id) => document.getElementById(id);
    const cardInner = $("card-inner"), cardBack = $("card-back"), flashcard = $("flashcard");
    const wordEs = $("word-es"), wordEn = $("word-en"), actions = $("actions");
    const flipPrompt = $("flip-prompt"), progressBar = $("progress-bar");
    const progressText = $("progress-text"), results = $("results");
    const resultsScore = $("results-score"), resultsDetail = $("results-detail");
    const cardContainer = $("card-container"), btnRestart = $("btn-restart");
    const btnRetryMistakes = $("btn-retry-mistakes");

    function shuffle(arr) { const a=[...arr]; for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];} return a; }

    const GK = "game_flashcards", EXP = 3600000;
    function save() { try { localStorage.setItem(GK, JSON.stringify({ currentCategory, deck, index, correct, mistakes, _t: Date.now() })); } catch {} }
    function load() { try { const r = localStorage.getItem(GK); if (!r) return null; const s = JSON.parse(r); if (Date.now() - s._t > EXP) { localStorage.removeItem(GK); return null; } return s; } catch { return null; } }
    function clear() { try { localStorage.removeItem(GK); } catch {} }

    function startRound(cards, fresh) { if (!fresh) { const saved = load(); if (saved) { currentCategory = saved.currentCategory; deck = saved.deck; index = saved.index; correct = saved.correct; mistakes = saved.mistakes; results.classList.add("hidden"); cardContainer.classList.remove("hidden"); actions.classList.add("hidden"); flipPrompt.classList.remove("hidden"); showCard(); return; } } deck=shuffle(cards); index=0; correct=0; mistakes=[]; flipped=false; results.classList.add("hidden"); cardContainer.classList.remove("hidden"); actions.classList.add("hidden"); flipPrompt.classList.remove("hidden"); showCard(); }
    function showCard() { flipped=false; cardInner.style.transform=""; cardBack.classList.add("invisible"); wordEs.textContent=deck[index].es; wordEn.textContent=""; actions.classList.add("hidden"); flipPrompt.classList.remove("hidden"); updateProgress(); }
    function flipCard() { if(flipped) return; flipped=true; wordEn.textContent=deck[index].en; cardBack.classList.remove("invisible"); cardInner.style.transform="rotateY(180deg)"; actions.classList.remove("hidden"); flipPrompt.classList.add("hidden"); }
    function next(gotIt) { if(gotIt) correct++; else mistakes.push(deck[index]); index++; if(index>=deck.length) { clear(); showResults(); } else { save(); showCard(); } }
    function updateProgress() { progressBar.style.width=(index/deck.length*100)+"%"; progressText.textContent=index+" / "+deck.length; }
    function showResults() { cardContainer.classList.add("hidden"); actions.classList.add("hidden"); flipPrompt.classList.add("hidden"); results.classList.remove("hidden"); const pct=Math.round(correct/deck.length*100); resultsScore.textContent=correct+" out of "+deck.length+" correct ("+pct+"%)"; if(!mistakes.length){resultsDetail.textContent="Perfect score!";btnRetryMistakes.classList.add("hidden");}else{resultsDetail.textContent=mistakes.length+" to review: "+mistakes.map(m=>m.es).join(", ");btnRetryMistakes.classList.remove("hidden");} progressBar.style.width="100%"; progressText.textContent=deck.length+" / "+deck.length; }

    flashcard.addEventListener("click", flipCard);
    document.addEventListener("keydown", (e) => { if(e.key===" "||e.key==="Enter"){if(!flipped){e.preventDefault();flipCard();}}else if(flipped&&index<deck.length){if(e.key==="ArrowLeft"||e.key==="1")next(false);else if(e.key==="ArrowRight"||e.key==="2")next(true);} });
    $("btn-again").addEventListener("click", () => next(false));
    $("btn-got-it").addEventListener("click", () => next(true));
    btnRestart.addEventListener("click", () => { clear(); startRound(allCategories[currentCategory], true); });
    btnRetryMistakes.addEventListener("click", () => { clear(); startRound(mistakes, true); });

    document.getElementById("btn-restart-mid").addEventListener("click", () => { clear(); startRound(allCategories[currentCategory], true); });

    document.querySelectorAll(".category-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        currentCategory = btn.dataset.category;
        document.querySelectorAll(".category-btn").forEach(b => { b.classList.remove("bg-primary","text-white"); b.classList.add("bg-gray-100","text-gray-600"); });
        btn.classList.remove("bg-gray-100","text-gray-600"); btn.classList.add("bg-primary","text-white");
        clear(); startRound(allCategories[currentCategory], true);
      });
    });
    startRound(allCategories[currentCategory]);
  </script>
  <style>
    .backface-hidden { -webkit-backface-visibility: hidden; backface-visibility: hidden; }
  </style>
</Layout>
