---
import Layout from "../../layouts/Layout.astro";
import { accentWords } from "../../data/accents";
---

<Layout title="Accent Fixer — Spanish with Elena Ramón">
  <section class="max-w-2xl mx-auto px-6 py-16">
    <div class="mb-8">
      <a href="/games" class="text-sm text-primary hover:underline">&larr; All Games</a>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold text-primary mb-2 text-center">Accent Fixer</h1>
    <p class="text-gray-500 text-center mb-8">The accents are missing! Click letters to add á, é, í, ó, ú, or ñ.</p>

    <div class="flex items-center gap-4 mb-6">
      <div class="flex-1 h-2.5 bg-gray-200 rounded-full overflow-hidden">
        <div id="progress-bar" class="h-full bg-primary rounded-full transition-all duration-300" style="width: 0%" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
      </div>
      <span id="progress-text" class="text-sm text-gray-500">0 / 10</span>
      <button id="btn-restart-mid" class="text-sm text-gray-500 hover:text-primary transition-colors cursor-pointer">Restart</button>
    </div>

    <div id="game">
      <div class="text-center mb-2">
        <p class="text-xs uppercase tracking-wider text-gray-500">English meaning</p>
        <p id="meaning" class="text-sm text-gray-500 italic"></p>
      </div>

      <!-- The word with clickable letters -->
      <div class="p-8 rounded-2xl border-2 border-primary/20 bg-white shadow-sm text-center mb-6">
        <div id="word-display" class="flex gap-1 justify-center text-4xl font-bold"></div>
      </div>

      <div class="flex gap-3 justify-center mb-4">
        <button id="btn-check" class="px-6 py-3 rounded-lg font-bold bg-primary text-white hover:bg-blue-700 transition-colors cursor-pointer">Check</button>
        <button id="btn-reset" class="px-4 py-3 rounded-lg font-bold border-2 border-gray-300 text-gray-500 hover:bg-gray-100 transition-colors cursor-pointer">Reset</button>
      </div>

      <p class="text-center text-xs text-gray-500 mb-2">Click a vowel to cycle: a &rarr; á &rarr; a | n &rarr; ñ &rarr; n</p>
      <p id="feedback" class="text-center text-sm h-5 font-bold" aria-live="polite"></p>
      <button id="btn-continue" class="mt-4 mx-auto block px-6 py-2 rounded-lg font-bold border-2 border-primary text-primary hover:bg-primary hover:text-white transition-colors hidden cursor-pointer">Continue</button>
    </div>

    <!-- Results -->
    <div id="results" class="text-center hidden">
      <p class="text-5xl mb-4" aria-hidden="true">&#127793;</p>
      <h2 class="text-2xl font-bold text-primary mb-2">Round Complete!</h2>
      <p id="result-score" class="text-gray-600 mb-2"></p>
      <p id="result-detail" class="text-sm text-gray-500 mb-6"></p>
      <button id="btn-restart" class="px-6 py-3 rounded-lg font-bold bg-primary text-white hover:bg-blue-700 transition-colors cursor-pointer">Play Again</button>
      <div class="mt-8 pt-6 border-t border-gray-200">
        <p class="text-sm text-gray-500 mb-3">Want to learn faster with a personal teacher?</p>
        <a href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ38hp0IO46XB7FQXk_vZXUAaaMVejyjSFGxa-NanSFJbN9S2_Asp_kl-_YddbRWDI3HbtKwGgcW" target="_blank" rel="noopener noreferrer" class="text-primary font-bold hover:underline text-sm">Book a free intro call with Elena</a>
      </div>
    </div>
  </section>

  <script define:vars={{ accentWords }}>
    const allWords = accentWords;
    const ROUND_SIZE = 10;

    // Accent cycling maps
    const accentMap = { "a": "á", "á": "a", "e": "é", "é": "e", "i": "í", "í": "i", "o": "ó", "ó": "o", "u": "ú", "ú": "u", "n": "ñ", "ñ": "n" };
    const stripMap = { "á": "a", "é": "e", "í": "i", "ó": "o", "ú": "u", "ñ": "n" };
    const clickable = new Set(["a", "e", "i", "o", "u", "n"]);

    let deck = [], index = 0, correct = 0, mistakes = [], letterEls = [];

    const $ = (id) => document.getElementById(id);
    const wordDisplay = $("word-display"), meaning = $("meaning"), feedback = $("feedback");
    const game = $("game"), results = $("results");
    const progressBar = $("progress-bar"), progressText = $("progress-text");

    function shuffle(a) { const b=[...a]; for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]];} return b; }

    const GK = "game_accent_fixer", EXP = 3600000;
    function save() { try { localStorage.setItem(GK, JSON.stringify({ deck, index, correct, mistakes, _t: Date.now() })); } catch {} }
    function load() { try { const r = localStorage.getItem(GK); if (!r) return null; const s = JSON.parse(r); if (Date.now() - s._t > EXP) { localStorage.removeItem(GK); return null; } return s; } catch { return null; } }
    function clear() { try { localStorage.removeItem(GK); } catch {} }

    function stripAccents(word) {
      return [...word].map(ch => stripMap[ch] || ch).join("");
    }

    function start(fresh) {
      const saved = !fresh && load();
      if (saved) { deck = saved.deck; index = saved.index; correct = saved.correct; mistakes = saved.mistakes; }
      else { deck = shuffle(allWords).slice(0, ROUND_SIZE); index = 0; correct = 0; mistakes = []; }
      results.classList.add("hidden"); game.classList.remove("hidden");
      $("btn-continue").classList.add("hidden");
      showWord();
    }

    function showWord() {
      const w = deck[index];
      meaning.textContent = w.en;
      feedback.textContent = "";
      letterEls = [];

      const stripped = stripAccents(w.correct.toLowerCase());
      wordDisplay.innerHTML = "";

      [...stripped].forEach((ch, i) => {
        const span = document.createElement("span");
        span.textContent = ch;
        span.dataset.index = String(i);
        span.dataset.current = ch;

        if (clickable.has(ch)) {
          span.className = "cursor-pointer px-2 py-2 rounded-lg hover:bg-primary/10 transition-colors text-primary select-none";
          span.addEventListener("click", () => cycleAccent(span));
        } else {
          span.className = "px-2 py-2 text-gray-800 select-none";
        }

        wordDisplay.appendChild(span);
        letterEls.push(span);
      });

      updateProgress();
    }

    function cycleAccent(span) {
      const current = span.dataset.current;
      const next = accentMap[current];
      if (next) {
        span.dataset.current = next;
        span.textContent = next;
        // Visual indication that it's been modified
        if (stripMap[next]) {
          span.classList.add("bg-primary/10", "font-black");
        } else {
          span.classList.remove("bg-primary/10", "font-black");
        }
      }
    }

    function check() {
      const w = deck[index];
      const userWord = letterEls.map(el => el.dataset.current).join("");
      const correctLower = w.correct.toLowerCase();

      if (userWord === correctLower) {
        correct++;
        letterEls.forEach(el => el.classList.add("text-green-700"));
        feedback.textContent = "Correct! " + w.correct;
        feedback.className = "text-center text-sm h-5 font-bold text-green-700";
        setTimeout(advance, 800);
      } else {
        mistakes.push(w);
        // Highlight wrong letters
        [...correctLower].forEach((ch, i) => {
          if (letterEls[i].dataset.current !== ch) {
            letterEls[i].classList.add("text-red-600");
            letterEls[i].textContent = ch;
            letterEls[i].dataset.current = ch;
          } else {
            letterEls[i].classList.add("text-green-700");
          }
        });
        feedback.textContent = "The correct word is: " + w.correct;
        feedback.className = "text-center text-sm h-5 font-bold text-red-600";
        $("btn-continue").classList.remove("hidden");
      }
    }

    function resetWord() {
      const w = deck[index];
      const stripped = stripAccents(w.correct.toLowerCase());
      letterEls.forEach((el, i) => {
        el.dataset.current = stripped[i];
        el.textContent = stripped[i];
        el.classList.remove("bg-primary/10", "font-black", "text-green-700", "text-red-600");
      });
      feedback.textContent = "";
    }

    function advance() {
      index++;
      if (index >= deck.length) {
        clear();
        game.classList.add("hidden");
        results.classList.remove("hidden");
        const pct = Math.round(correct / deck.length * 100);
        $("result-score").textContent = correct + " out of " + deck.length + " correct (" + pct + "%)";
        if (mistakes.length) {
          $("result-detail").textContent = "Review: " + mistakes.map(m => m.correct).join(", ");
        } else {
          $("result-detail").textContent = "Perfect accents!";
        }
        progressBar.style.width = "100%";
        progressText.textContent = deck.length + " / " + deck.length;
      } else {
        save();
        showWord();
      }
    }

    function updateProgress() {
      progressBar.style.width = (index / deck.length * 100) + "%";
      progressText.textContent = index + " / " + deck.length;
    }

    $("btn-continue").addEventListener("click", () => { $("btn-continue").classList.add("hidden"); advance(); });
    $("btn-check").addEventListener("click", check);
    $("btn-reset").addEventListener("click", resetWord);
    $("btn-restart").addEventListener("click", () => { clear(); start(true); });
    $("btn-restart-mid").addEventListener("click", () => { clear(); start(true); });
    start();
  </script>
</Layout>
